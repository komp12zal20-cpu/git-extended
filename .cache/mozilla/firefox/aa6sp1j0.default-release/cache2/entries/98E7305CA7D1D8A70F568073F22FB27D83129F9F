<h2>Version numbering</h2>
<div>
  <p>
  Since version 3.0.0, QEMU uses a time based version numbering scheme:
  </p>
<dl>
<dt>major</dt>
<dd>incremented by 1 for the first release of the year</dd>
<dt>minor</dt>
<dd>reset to 0 with every major increment, otherwise incremented by 1 for each release from git master</dd>
<dt>micro</dt>
<dd>always 0 for releases from git master, incremented by 1 for each stable branch release</dd>
</dl>
  <p>
    The implication of this is that changes in major version number
    <strong>do not</strong> have any bearing on the scope of changes
    included in the release. Non-backward compatible changes may be made
    in any master branch release, provided they have followed the
    <a href="https://www.qemu.org/docs/master/about/deprecated.html">deprecation
    policy</a> which calls for warnings to be emitted for a minimum of two
    releases prior to the change.
  </p>
</div>
<script>
(() => {
  const horizMenu = document.querySelector('.horiz-menu');
  const menuList = horizMenu.querySelector('ul');
  const menuLinks = horizMenu.querySelectorAll('ul a');
  const articles = horizMenu.querySelectorAll('article');
  const articleHeaders = horizMenu.querySelectorAll('article > header');

  const animateOnClick = (element) => {
    const activeItems = horizMenu.querySelectorAll('ul li.active');
    activeItems.forEach(li => li.classList.remove('active'));
    element.parentElement.classList.add('active');

    const currentActive = horizMenu.querySelectorAll('article.active');
    const target = horizMenu.querySelector(element.getAttribute('href'));

    currentActive.forEach(article => article.classList.remove('active'));
    target.classList.add('active');
  };

  menuList.style.display = 'block';
  articleHeaders.forEach(header => {
     header.style.display = 'none';
  });

  menuLinks.forEach(link => {
     link.addEventListener('click', (e) => {
        e.preventDefault();
        if (!link.parentElement.classList.contains('active')) {
          history.replaceState(null, null, link.getAttribute('href'));
          animateOnClick(link);
        }
     });
  });

  let elem;
  articles.forEach(article => article.classList.remove('active'));

  const hash = window.location.hash;
  const hashElement = hash ? document.getElementById(hash.replace('#', '')) : null;

  if (hash && hashElement && hashElement.tagName === 'ARTICLE') {
    elem = horizMenu.querySelector(`a[href="${hash}"]`);
  } else {
    elem = menuLinks[0];
  }

  animateOnClick(elem);
  articles.forEach(article => {
    article.classList.add('animate');
  });
})();
</script>

